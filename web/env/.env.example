# Local Development Environment Variables
# Copy this file to env/.env and fill in your values

# Database (Neon PostgreSQL - use pooler hostname)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST-pooler.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=10&pool_timeout=10"

# Auth
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Worker service URL
WORKER_URL="http://localhost:3001"

# OpenAI (for AI recommendations)
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# Email (Zoho SMTP)
SMTP_HOST="smtp.zohocloud.ca"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="your-email@yourdomain.com"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
