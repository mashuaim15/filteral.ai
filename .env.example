# Database (local PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dailyrec"
DB_PASSWORD="postgres"

# Auth
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Worker
WORKER_URL="http://localhost:3001"

# OpenAI (required for AI recommendations)
OPENAI_API_KEY="sk-..."

# Google OAuth (for YouTube login)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Email (Zoho SMTP)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="hello@filteral.app"
SMTP_PASS="your-smtp-password"
SMTP_FROM="hello@filteral.app"

# Stripe (optional for development)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# Encryption (for auth state storage, optional)
ENCRYPTION_KEY="generate-32-byte-hex-key"
